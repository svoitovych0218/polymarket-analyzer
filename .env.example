# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — used by the LLM grouper (Claude Haiku)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────

# LLM provider: "claude" (default) or "openai" (uses GPT-4o-mini)
# LLM_PROVIDER=claude

# OpenAI API key — only required when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Delay between LLM calls in milliseconds (default: 0)
# Set to 3000 when using OpenAI free/tier-1 to avoid 429 rate limit errors
# LLM_CALL_DELAY_MS=3000

# Max markets per LLM call (default: 50)
# Reduce to 20–30 when using OpenAI to avoid 400 context-limit errors on large buckets
# BUCKET_CHUNK_SIZE=30

# Path to the NDJSON mismatch log file
# Default: data/mismatches.ndjson
# MISMATCH_LOG_PATH=data/mismatches.ndjson
