# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — used by the LLM grouper (Claude Haiku)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────

# LLM provider: "claude" (default) or "openai" (uses GPT-4o-mini)
# LLM_PROVIDER=claude

# OpenAI API key — only required when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Path to the NDJSON mismatch log file
# Default: data/mismatches.ndjson
# MISMATCH_LOG_PATH=data/mismatches.ndjson
